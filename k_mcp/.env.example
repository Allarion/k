K_BINARY=./bin/k
K_REPO_ROOT=~/.k/repo
LEGACY_SOURCE_ROOT=~/legacy-notes
LEGACY_NOTES_DIRECTORY=~/legacy-notes
K_ALLOWED_COMMANDS=help,scope,draft,jot,today,resume,new,save,todo,find
K_COMMAND_TIMEOUT_SECONDS=20
K_MAX_STDOUT_BYTES=65536
K_MAX_STDERR_BYTES=65536
K_MCP_FEEDBACK_DIR=~/.k/repo/.k-mcp-feedback
LOG_LEVEL=INFO
